{
  "entry": ["src/**/*.ts"],
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "templates/**",
    "public/**",
    "scripts/**",
    "**/__fixtures__/**",
    "**/*.test.ts"
  ],
  "rules": {
    "unused-types": "warn",
    "duplicate-exports": "warn",
    "unresolved-imports": "warn"
  }
}
