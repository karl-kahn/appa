# Required: Anthropic API key for spawned Claude CLI sessions.
# Get one at https://console.anthropic.com/ — note that each chat round
# costs real money against this key (Sonnet ~$3/M input + $15/M output,
# Haiku ~$1/M+$5/M).
ANTHROPIC_API_KEY=

# Optional: bind port/host (defaults: 3848 / 127.0.0.1)
PORT=3848
HOST=127.0.0.1

# Optional: override settings from appa.config.js at runtime. Useful
# when deploying the same checked-in config to multiple environments.
# APPA_PROJECT_DIR=/path/to/your/team-project
# APPA_MODEL=haiku
