# Required: Anthropic API key for spawned Claude CLI sessions.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: where Appa stores project data (team.json, transcripts/, etc.).
# Defaults to current working directory.
APPA_PROJECT_DIR=

# Optional: port to bind (default 3848) and host (default 127.0.0.1).
PORT=3848
HOST=127.0.0.1

# Optional: model passed to claude -p (default sonnet).
APPA_MODEL=sonnet

# Optional: spawn rate limits. Hourly default 20, daily 100.
APPA_HOURLY_LIMIT=20
APPA_DAILY_LIMIT=100
