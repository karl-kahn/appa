{
  "name": "appa",
  "version": "0.1.0",
  "description": "A web chat tutor + team workspace kernel. Spawns Claude CLI sessions with a project-specific persona and exposes modular tabs (tasks, photos, activity, custom modules). Originally extracted from kidwind-worlds.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./modules/tasks": {
      "import": "./dist/modules/tasks/index.js",
      "types": "./dist/modules/tasks/index.d.ts"
    },
    "./modules/photos": {
      "import": "./dist/modules/photos/index.js",
      "types": "./dist/modules/photos/index.d.ts"
    },
    "./modules/activity": {
      "import": "./dist/modules/activity/index.js",
      "types": "./dist/modules/activity/index.d.ts"
    }
  },
  "bin": {
    "appa": "./dist/cli.js",
    "create-appa": "./dist/scaffold/create.js"
  },
  "files": ["dist/", "templates/", "public/", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run format && npm run lint && npm run typecheck && npm run test && npm run lint:dead",
    "lint:dead": "knip && fallow dead-code"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["claude", "chat", "tutor", "education", "classroom", "kidwind", "team", "express"],
  "author": "Karl Kahn",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "fallow": "*",
    "knip": "*",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
